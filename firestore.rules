rules_version = '2';  
service cloud.firestore {  
  match /databases/{database}/documents {  
    match /users/{uid} { allow read: if request.auth != null; allow write: if request.auth != null && request.auth.uid == uid; }  
    match /matches/{matchId} { allow read, write: if request.auth != null && (request.auth.uid == resource.data.userA || request.auth.uid == resource.data.userB); allow create: if request.auth != null; }  
    match /messages/{msgId} { allow read, write: if request.auth != null; }  
    match /settings/{doc} { allow read: if request.auth != null; allow write: if request.auth != null && request.auth.token.email == 'admin@veya.app'; }  
  }  
}  
